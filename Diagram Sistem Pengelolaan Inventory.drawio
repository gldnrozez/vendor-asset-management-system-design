        <mxCell id="m2GnGXG3_wBxYranVg4I-5" value="&lt;div&gt;Sistem&lt;/div&gt;" style="swimlane;whiteSpace=wrap;html=1;container=0;movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;" vertex="1" parent="1">
